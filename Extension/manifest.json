{
  "manifest_version": 3,
  "name": "AI Anonimizzatore Chat",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [{
    "matches": [
      "*://*.chatgpt.com/*",
      "*://*.gemini.google.com/*",
      "*://*.claude.ai/*"
    ],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}